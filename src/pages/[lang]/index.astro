---
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' };

// Rutas base con trailing slash para consistencia SEO
const enPath = "/en/";
const esPath = "/es/";
const ogImage = "/home/IMG-1.webp";

import Layout from "../../layouts/Layout.astro";
import HeaderHome from "../../components/home/HeaderHome.astro";
import AboutLux from "../../components/home/AboutLux.astro";
import ServicesLux from "../../components/home/ServicesLux.astro";
import DentalTourism from "../../components/home/DentalTourism.astro";
import WhyChooseUs from "../../components/home/WhyChooseUs.astro";
import ReviewsLux from "../../components/home/ReviewsLux.astro";
import LocationLux from "../../components/home/LocationLux.astro";
import FAQ from "../../components/home/FAQ.astro";
import ContactForm from "../../components/shared/ContactForm.astro";
import TeamComponent from "../../components/shared/TeamComponent.astro";

const seoData = {
  en: {
    title: "Dentist in Playa del Carmen | Implants, Veneers & Smile Design",
    description: "Your trusted dentist in Playa del Carmen. Stetic Dental offers implants, veneers and cosmetic dentistry for international patients",
  },
  es: {
    title: "Stetic Dental Playa del Carmen | Clínica Dental de Confianza",
    description: "Clínica dental en Playa del Carmen especialista en implantes, carillas, diseño de sonrisa y turismo dental con tecnología avanzada.",
  }
};

const currentSeo = seoData[lang];

// 1. EXTRAEMOS LA INFORMACIÓN DEL EQUIPO DENTAL
const teamData = {
  en: {
    title: "Trusted Dental Specialists for International Patients",
    description: "Choosing the right dental team is one of the most important decisions when planning treatment abroad. Our specialists provide personalized care, clear communication in English, and modern dental solutions designed to help patients travel confidently to Playa del Carmen for their treatment.",
    specialists: [
      {
        name: "Dr. Ana Sofía Martínez",
        specialty: "Orthodontics & Invisalign Specialist",
        image: "/images/team/dra-ana-sofia.jpg",
        bio: "Certified Invisalign provider with over 10 years of experience designing perfect smiles for international patients."
      },
      {
        name: "Dr. Carlos Rivera",
        specialty: "Implantology & Oral Surgery",
        image: "/images/team/dr-carlos-rivera.jpg",
        bio: "Expert in complex dental implant procedures and full-mouth restorations, ensuring functional and aesthetic results."
      },
      {
        name: "Dr. Elena Gómez",
        specialty: "Cosmetic Dentistry",
        image: "/images/team/dra-elena-gomez.jpg",
        bio: "Specializes in porcelain veneers and smile makeovers, combining art and science to create stunning, natural looks."
      }
    ]
  },
  es: {
    title: "Especialistas Dentales de Confianza para Pacientes Internacionales",
    description: "Elegir el equipo dental adecuado es una de las decisiones más importantes al planificar un tratamiento en el extranjero. Nuestros especialistas brindan atención personalizada, comunicación clara y soluciones dentales modernas para ayudar a los pacientes a viajar con confianza a Playa del Carmen.",
    specialists: [
      {
        name: "Dra. Ana Sofía Martínez",
        specialty: "Especialista en Ortodoncia e Invisalign",
        image: "/images/team/dra-ana-sofia.jpg",
        bio: "Proveedor certificado de Invisalign con más de 10 años de experiencia diseñando sonrisas perfectas para pacientes internacionales."
      },
      {
        name: "Dr. Carlos Rivera",
        specialty: "Implantología y Cirugía Bucal",
        image: "/images/team/dr-carlos-rivera.jpg",
        bio: "Experto en procedimientos complejos de implantes dentales y restauraciones de boca completa, asegurando resultados funcionales y estéticos."
      },
      {
        name: "Dra. Elena Gómez",
        specialty: "Odontología Estética",
        image: "/images/team/dra-elena-gomez.jpg",
        bio: "Especialista en carillas de porcelana y diseño de sonrisa, combinando arte y ciencia para crear looks impresionantes y naturales."
      }
    ]
  }
};

const currentTeam = teamData[lang];

// 2. LIMPIAMOS EL SCHEMA PARA QUE SEA VÁLIDO PARA SEO
const schemas = {
  en: {
    "@context": "https://schema.org",
    "@type": "Dentist",
    "@id": "https://www.steticdental.com.mx/en/#dentist",
    "url": "https://www.steticdental.com.mx/en/",
    "telephone": "+52 984 188 0338",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"], "opens": "10:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "10:00", "closes": "17:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "14:00" }
    ]
  },
  es: {
    "@context": "https://schema.org",
    "@type": "Dentist",
    "@id": "https://www.steticdental.com.mx/es/#dentist",
    "url": "https://www.steticdental.com.mx/es/",
    "telephone": "+52 984 188 0338",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"], "opens": "10:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "10:00", "closes": "17:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "10:00", "closes": "14:00" }
    ]
  }
};

const currentSchema = schemas[lang];
---

<Layout 
  title={currentSeo.title} 
  description={currentSeo.description} 
  lang={lang}
  enPath={enPath}
  esPath={esPath}
  schema={currentSchema}
  ogImage={ogImage}
>
    <HeaderHome lang={lang} />

    <AboutLux lang={lang} />

    <ServicesLux lang={lang} />
    
    <!-- <TeamComponent 
      title={currentTeam.title}
      description={currentTeam.description}
      specialists={currentTeam.specialists} 
    /> -->
    
    <DentalTourism lang={lang} />

    <WhyChooseUs lang={lang} />

    <ReviewsLux lang={lang} />

    <LocationLux lang={lang} />

    <FAQ lang={lang} />

    <ContactForm lang={lang} />
</Layout>