        "Logra la sonrisa que siempre quisiste de forma invisible. Estamos listos para ayudarte.",
      button: "Reserva tu Consulta Ahora",
      note: "Comienza tu transformación hoy",
    },

    buttonText: "Agenda tu consulta de alineadores transparentes → ",
    whatsappUrl: `https://wa.me/5219844922549/?text=${encodeURIComponent("¡Hola! Estaba revisando la sección de alineadores transparentes en su sitio web y me interesa agendar una cita. ¿Podrían informarme sobre los horarios disponibles? ¡Gracias!")}`,
  },
};

const t = pageContent[lang];
---

<Layout
  title={t.seo.title}
  description={t.seo.description}
  lang={lang}
  enPath={enPath}
  esPath={esPath}
  schema={t.schema}
  ogImage={ogImage}
>
  <HeaderSpeciality
    lang={lang}
    title={t.header.title}
    subheadline={t.header.subheadline}
    features={t.header.features}
    imageSrc={t.header.imageSrc}
    imageAlt={t.header.imageAlt}
    buttonText={t.buttonText}
    buttonLink={t.whatsappUrl}
  />

  <AboutSpeciality
    title={t.about.title}
    text1={t.about.text1}
    text2={t.about.text2}
    imageSrc={t.about.imageSrc}
    imageAlt={t.about.imgAlt}
  />

  <WhatIsSpeciality
    title={t.whatIs.title}
    text1={t.whatIs.text1}
    text2={t.whatIs.text2}
  />

  <ComparisonSpeciality
    title={t.comparison.title}
    text1={t.comparison.text1}
    text2={t.comparison.text2}
  />
  <CompareTableInvisalign
    title={t.comparison.titleTable}
    description={t.comparison.descriptionTable}
    footer={t.comparison.footerTable}
  />
  <ButtonCTA
    text={t.buttonText}
    href={t.whatsappUrl}
    openInNewTab={true}
    align="center"
  />
  <CandidateSpeciality
    title={t.candidate.title}
    description={t.candidate.description}
    items={t.candidate.items}
    footerText={t.candidate.footerText}
    imageSrc={t.candidate.imageSrc}
    imageAlt={t.candidate.imageAlt}
  />

  <ProcessSpeciality
    title={t.process.title}
    footer={t.process.footer}
    steps={t.process.steps}
  />

  <CostSpeciality
    title={t.cost.title}
    text1={t.cost.text1}
    text2={t.cost.text2}
  />

  <WhyChooseSpeciality
    title={t.whyChoose.title}
    description={t.whyChoose.description}
    items={t.whyChoose.items}
    footerText={t.whyChoose.footerText}
    reelId={t.whyChoose.reelId}
  />

  <ResultSpeciality
    title={t.results.title}
    text1={t.results.text1}
    imageSrc={t.results.imageSrc}
    imageAlt={t.results.imgAlt}
  />

  <LocationSpeciality
    title={t.location.title}
    text1={t.location.text1}
    mapUrl={t.location.mapUrl}
    whatsappUrl={t.location.whatsappUrl}
  />

  <FaqSpeciality title={t.faq.title} faqs={t.faq.items} />

  <CtaSpeciality
    lang={lang}
    title={t.cta.title}
    description={t.cta.description}
    buttonText={t.cta.button}
    note={t.cta.note}
  />
</Layout>
