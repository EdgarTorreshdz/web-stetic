---
// src/pages/[lang]/[invisalign].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        invisalign: routes.en.invisalign 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        invisalign: routes.es.invisalign 
      } 
    },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' };

const enPath = `/en/${routes.en.invisalign}/`;
