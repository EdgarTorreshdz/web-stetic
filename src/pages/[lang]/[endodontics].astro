        { title: "Temporary or permanent restoration" }
      ]
    },
    after: {
      title: "After Root Canal Treatment: What to Expect",
      text1: "After treatment, most patients experience significant pain relief. In many cases, a dental crown is recommended to protect the treated tooth.",
      text2: "Our team will guide you through recovery and follow-up care.",
      imageSrc: "/sonrisa3.jpg",
      imgAlt: "Patient recovery and dental care after root canal"
    },
    americans: {
      title: "Root Canal Treatment for Americans in Mexico",
      text1: "Many patients choose Mexico because they receive professional care, English-speaking support, and significant savings (often 50% to 70%).",
