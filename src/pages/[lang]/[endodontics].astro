      ],
      footer: "Nuestro enfoque se centra en tu comodidad y salud bucal duradera.",
      imageSrc: ogImage,
      imgAlt: "Sonrisa saludable después de una endodoncia exitosa"
    },
    cost: {
      title: "Costo de Endodoncia en México",
      text1: "El costo es mucho más accesible que en EE. UU. o Canadá. El precio final depende de la complejidad y el diente afectado.",
      text2: "Brindamos información clara y planes de tratamiento sin cargos ocultos.",
    },
    process: {
      title: "Proceso del Tratamiento",
      footer: "Diseñado para eliminar el dolor de manera eficiente.",
      steps: [
