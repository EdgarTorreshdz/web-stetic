const t = pageContent[lang];
---

<Layout 
  title={t.seo.title} 
  description={t.seo.description} 
  lang={lang}
  enPath={enPath}
  esPath={esPath}
  schema={t.schema}
  ogImage={ogImage}
>
    <HeaderSpeciality 
      lang={lang}
      title={t.header.title}
      subheadline={t.header.subheadline}
      features={t.header.features}
      buttonText={t.header.button}
      imageSrc={t.header.imageSrc} 
      imageAlt={t.header.imageAlt}
    />

    <AboutSpeciality 
      title={t.about.title}
      text1={t.about.text1}
      text2={t.about.text2}
      imageSrc={t.about.imageSrc}
      imageAlt={t.about.imgAlt}
    />

    <WhatIsSpeciality 
      title={t.whatIs.title}
      text1={t.whatIs.text1}
      text2={t.whatIs.text2}
    />

    <IndicationsSpeciality 
      title={t.indications.title}
      subtitle={t.indications.subtitle}
      features={t.indications.features}
      footerText={t.indications.footerText}
    />    

    <SpecialistSpeciality 
      title={t.specialist.title}
      text1={t.specialist.text1}
      text2={t.specialist.text2}
      imageSrc={t.specialist.imageSrc}
      imageAlt={t.specialist.imgAlt}
    />

    <BenefitsSpeciality 
      title={t.benefits.title}
      benefits={t.benefits.items}
      footerText={t.benefits.footer}
      imageSrc={t.benefits.imageSrc}
      imageAlt={t.benefits.imgAlt}
    />

    <CostSpeciality 
      title={t.cost.title}
      text1={t.cost.text1}
      text2={t.cost.text2}
    />

    <ProcessSpeciality 
      title={t.process.title}
      footer={t.process.footer}
      steps={t.process.steps}
    />

    <AfterSpeciality 
      title={t.after.title}
      text1={t.after.text1}
      text2={t.after.text2}
      imageSrc={t.after.imageSrc}
      imageAlt={t.after.imgAlt}
    />

    <AmericansSpeciality 
      title={t.americans.title}
      text1={t.americans.text1}
    />

    <LocationSpeciality 
      title={t.location.title}
      text1={t.location.text1}
      mapUrl={t.location.mapUrl}
    />

    <FaqSpeciality 
      title={t.faq.title}
      faqs={t.faq.items}
    />

    <CtaSpeciality 
      lang={lang}
      title={t.cta.title}
      description={t.cta.description}
      buttonText={t.cta.button}
      note={t.cta.note}
    />
</Layout>