      imageSrc: "/sonrisa3.jpg",
      imgAlt: "Recuperación del paciente"
    },
    americans: {
      title: "Atención para Pacientes Internacionales",
      text1: "Ofrecemos atención profesional con apoyo bilingüe y ahorros de hasta el 70% comparado con precios en el extranjero.",
