---
// src/pages/[lang]/[endodontics].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    {
      params: {
        lang: "en",
        endodontics: routes.en.endodontics,
      },
    },
    {
      params: {
        lang: "es",
        endodontics: routes.es.endodontics,
      },
    },
  ];
}

