        { title: "Eliminación del tejido infectado" },
        { title: "Limpieza y sellado del conducto" },
        { title: "Restauración de la pieza" }
      ]
    },
    after: {
      title: "Después del Tratamiento",
      text1: "La mayoría de los pacientes sienten alivio inmediato. A menudo se recomienda una corona para proteger el diente.",
