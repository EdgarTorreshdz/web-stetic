---
// src/pages/[lang]/[endodontics].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        endodontics: routes.en.endodontics 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        endodontics: routes.es.endodontics 
      } 
    },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' };

const enPath = `/en/${routes.en.endodontics}/`;
const esPath = `/es/${routes.es.endodontics}/`;
const imgPath = `/root_canal_treatment/`;
const ogImage = `${imgPath}Root-canal-IMG-4.webp`;

import HeaderSpeciality from "../../components/shared/HeaderSpeciality.astro";
import AboutSpeciality from "../../components/shared/AboutSpeciality.astro";
import WhatIsSpeciality from "../../components/shared/WhatIsSpeciality.astro";
import IndicationsSpeciality from "../../components/shared/IndicationsSpeciality.astro";
import SpecialistSpeciality from "../../components/shared/SpecialistSpeciality.astro";
import BenefitsSpeciality from "../../components/shared/BenefitsSpeciality.astro";
import CostSpeciality from "../../components/shared/CostSpeciality.astro";
import ProcessSpeciality from "../../components/shared/ProcessSpeciality.astro";
import AfterSpeciality from "../../components/shared/AfterSpeciality.astro";
import AmericansSpeciality from "../../components/shared/AmericansSpeciality.astro";
import LocationSpeciality from "../../components/shared/LocationSpeciality.astro";
import FaqSpeciality from "../../components/shared/FaqSpeciality.astro";
import CtaSpeciality from "../../components/shared/CtaSpeciality.astro";

const pageContent = {
  en: {
    schema: {
      "@context": "https://schema.org",
      "@graph": [
