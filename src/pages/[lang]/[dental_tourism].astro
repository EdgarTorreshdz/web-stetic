---
// src/pages/[lang]/[dental_tourism].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        dental_tourism: routes.en.dental_tourism 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        dental_tourism: routes.es.dental_tourism 
      } 
    },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' };

const enPath = `/en/${routes.en.dental_tourism}/`;
const esPath = `/es/${routes.es.dental_tourism}/`;
const imgPath = '/dental_tourism/';
const ogImage = `${imgPath}Dental-Tourism-IMG-1.webp`;

import HeaderSpeciality from "../../components/shared/HeaderSpeciality.astro";
import AboutSpeciality from "../../components/shared/AboutSpeciality.astro";
import WhatIsSpeciality from "../../components/shared/WhatIsSpeciality.astro";
import TourismPackages from "../../components/shared/TourismPackages.astro";
import PopularTreatments from "../../components/shared/PopularTreatments.astro";
import LocationSpeciality from "../../components/shared/LocationSpeciality.astro";
import CostSpeciality from "../../components/shared/CostSpeciality.astro";
import PlanningTourism from "../../components/shared/PlanningTourism.astro";
import WhyChooseSpeciality from "../../components/shared/WhyChooseSpeciality.astro";
import FaqSpeciality from "../../components/shared/FaqSpeciality.astro";
import CtaSpeciality from "../../components/shared/CtaSpeciality.astro";

const pageContent = {
