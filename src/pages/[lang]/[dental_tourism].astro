          "name": "Turismo Dental en México",
          "serviceType": "Paquetes de turismo dental y coordinación de tratamiento",
          "description": "Turismo dental en México con tratamientos asequibles en Playa del Carmen y apoyo para pacientes internacionales.",
          "url": `https://www.steticdental.com.mx${esPath}`,
          "provider": { "@id": `https://www.steticdental.com.mx${esPath}#dentist` },
          "areaServed": [
            { "@type": "City", "name": "Playa del Carmen" },
            { "@type": "Country", "name": "Mexico" }
          ]
        }
      ]
    },
    seo: {
      title: "Turismo Dental en México | Ahorra en tu Tratamiento Dental",
      description: "Turismo dental en México con atención asequible en Playa del Carmen. Tratamientos personalizados, paquetes de turismo dental y dentistas expertos."
    },
    header: {
      title: "Turismo Dental en México",
      subheadline: "Atención dental de alta calidad en México para pacientes internacionales que buscan un tratamiento seguro y profesional.",
      features: ["Especialistas experimentados", "Tecnología moderna", "Equipos bilingües", "Ahorros significativos"],
