---
// src/pages/[lang]/[orthodontics].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { params: { lang: 'en', orthodontics: routes.en.orthodontics } },
    { params: { lang: 'es', orthodontics: routes.es.orthodontics } },
  ];
}

const { lang } = Astro.params as { lang: 'en' | 'es' };

// Rutas base con trailing slash
const enPath = `/en/${routes.en.orthodontics}/`;
const esPath = `/es/${routes.es.orthodontics}/`;
const imgPath = `/orthodontists/`;
const ogImage = `${imgPath}Orthodontist-IMG-1.webp`;

import HeaderSpeciality from "../../components/shared/HeaderSpeciality.astro";
