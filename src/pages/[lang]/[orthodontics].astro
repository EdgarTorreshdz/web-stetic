const t = orthoContent[lang];
---

<Layout 
  title={t.seoTitle} 
  description={t.seoDescription} 
  lang={lang}
  enPath={enPath}
  esPath={esPath}
  schema={t.schema}
  ogImage={ogImage}
>
  <HeaderSpeciality 
      lang={lang}
      title={t.header.title}
      subheadline={t.header.subheadline}
      features={t.header.features}
      buttonText={t.header.button}
      imageSrc={t.header.imageSrc} 
      imageAlt={t.header.imgAlt}
    />

  <AboutSpeciality 
      title={t.about.title}
      text1={t.about.text1}
      text2={t.about.text2}
      imageSrc={t.about.imageSrc}  
      imageAlt={t.about.imgAlt}
    />

  <WhatIsSpeciality 
      title={t.whatIs.title}
      text1={t.whatIs.text1}
      text2={t.whatIs.text2}
    />

    <OptionsSpeciality 
      title={t.options.title}
      description={t.options.description}
      options={t.options.items}
    />

    <AdultsSpeciality 
      title={t.adults.title}
      text1={t.adults.text1}
      text2={t.adults.text2}
      imageSrc={t.adults.imgSrc} 
      imageAlt={t.adults.imgAlt}
    />

    <WhyChooseSpeciality 
    title={t.whyChoose.title}
    description={t.whyChoose.description}
    items={t.whyChoose.items}
    footerText={t.whyChoose.footerText}
    reelId={t.whyChoose.reelId}
  />

  <CostSpeciality 
      title={t.cost.title}
      text1={t.cost.text1}
      text2={t.cost.text2}
    />

    <ProcessSpeciality 
      title={t.process.title}
      footer={t.process.footer}
      steps={t.process.steps}
    />

    <AmericansSpeciality 
      title={t.americans.title}
      text1={t.americans.text1}
    />

    <LocationSpeciality 
      title={t.location.title}
      text1={t.location.text1}
      mapUrl={t.location.mapUrl}
      whatsappUrl={t.location.whatsappUrl}
    />

    <FaqSpeciality 
      title={t.faq.title}
      faqs={t.faq.items}
    />

    <CtaSpeciality 
      lang={lang}
      title={t.cta.title}
      description={t.cta.description}
      buttonText={t.cta.buttonText}
      note={t.cta.note}
    />
</Layout>