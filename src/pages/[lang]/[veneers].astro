---
// src/pages/[lang]/[veneers].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        veneers: routes.en.veneers 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        veneers: routes.es.veneers 
      } 
    },
  ];
}

