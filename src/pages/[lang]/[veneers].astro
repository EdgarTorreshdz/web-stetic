const t = pageContent[lang];
---

<Layout 
  title={t.seo.title} 
  description={t.seo.description} 
  lang={lang}
  enPath={enPath}
  esPath={esPath}
  schema={t.schema}
  ogImage={ogImage}
>
  <HeaderSpeciality 
      lang={lang}
      title={t.header.title}
      subheadline={t.header.subheadline}
      features={t.header.features}
      buttonText={t.header.button}
      imageSrc={t.header.imageSrc} 
      imageAlt={t.header.imageAlt}
    />

  <AboutSpeciality 
      title={t.about.title}
      text1={t.about.text1}
      text2={t.about.text2}
      imageSrc={t.about.imageSrc}
      imageAlt={t.about.imgAlt}
    />

  <WhatIsSpeciality 
      title={t.whatIs.title}
      text1={t.whatIs.text1}
      text2={t.whatIs.text2}
    />

  <BenefitsSpeciality 
      title={t.benefits.title}
      benefits={t.benefits.items}
      footerText={t.benefits.footer}
      imageSrc={t.benefits.imageSrc}
      imageAlt={t.benefits.imgAlt}
    />

  <CandidateSpeciality 
    title={t.candidate.title}
    description={t.candidate.description}
    items={t.candidate.items}
    footerText={t.candidate.footerText}
    imageSrc={t.candidate.imageSrc}
    imageAlt={t.candidate.imageAlt}
  />

  <CostSpeciality 
      title={t.cost.title}
      text1={t.cost.text1}
      text2={t.cost.text2}
    />

  <WhyChooseSpeciality 
      title={t.whyChoose.title}
      items={t.whyChoose.items}
      footerText={t.whyChoose.footerText}
      reelId={t.whyChoose.reelId}
    />

  <ProcessSpeciality 
      title={t.process.title}
      footer={t.process.footer}
      steps={t.process.steps}
    />

  <BeforeAfter 
      title={t.results.title}
      description={t.results.text1}
      beforeImage={imgPath + "Veneers-IMG-5.webp"}
      afterImage={imgPath + "Veneers-IMG-6.webp"}
      beforeLabel={t.results.beforeLabel}
      afterLabel={t.results.afterLabel}
    />

  <DesignIntegrationSpeciality 
      title={t.designIntegration.title}
      text1={t.designIntegration.text1}
      text2={t.designIntegration.text2}
    />

  <LocationSpeciality 
      title={t.location.title}
      text1={t.location.text1}
      mapUrl={t.location.mapUrl}
    />

  <FaqSpeciality 
      title={t.faq.title}
      faqs={t.faq.items}
    />

  <CtaSpeciality 
      lang={lang}
      title={t.cta.title}
      description={t.cta.description}
      buttonText={t.cta.button}
      note={t.cta.note}
    />
</Layout>