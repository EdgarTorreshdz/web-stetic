---
// src/pages/[lang]/[teeth_cleaning].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        teeth_cleaning: routes.en.teeth_cleaning 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        teeth_cleaning: routes.es.teeth_cleaning 
      } 
    },
  ];
}

