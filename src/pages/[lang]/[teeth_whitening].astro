---
// src/pages/[lang]/[teeth_whitening].astro
import { routes } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        lang: 'en', 
        teeth_whitening: routes.en.teeth_whitening 
      } 
    },
    { 
      params: { 
        lang: 'es', 
        teeth_whitening: routes.es.teeth_whitening 
      } 
    },
  ];
}

