---
export async function getStaticPaths() {
  return [
    { params: { lang: 'en', contact: 'contact' } },
    { params: { lang: 'es', contact: 'contacto' } },
  ];
}
const { lang } = Astro.params as { lang: 'en' | 'es' };
import Layout from "../../layouts/Layout.astro";
import ContactForm from "../../components/shared/ContactForm.astro";

const enPath = "/en/contact";
const esPath = "/es/contacto";

const titles = {
  en: "Dentist in Veracruz & Playa del Carmen | Stetic Dental Clinic",
  es: "Dentista en Veracruz & Playa del Carmen | Stetic Dental Clinic"
};

---

<Layout title={titles[lang]} lang={lang} enPath={enPath} esPath={esPath}>
    <ContactForm lang={lang} />
</Layout>
