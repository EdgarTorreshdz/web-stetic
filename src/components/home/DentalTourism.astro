---
import { Icon } from "astro-icon/components";

interface Props {
  lang?: 'en' | 'es';
}

const { lang = "en" } = Astro.props;

const translations = {
  en: {
    title: "Dental Tourism in Mexico: Why Choose Playa del Carmen?",
    text1: "Dental tourism in Mexico has become one of the most popular options for patients seeking high-quality and affordable care. Playa del Carmen offers modern dental clinics, experienced specialists, and significantly lower costs compared to the United States and Canada.",
    text2: "Patients choose Playa del Carmen not only for affordable dental care, but also for safety, accessibility, and a comfortable recovery environment. If you are looking for a trusted dentist in Playa del Carmen, you can expect personalized treatment, advanced technology, and a smooth experience from your first consultation to post-treatment follow-up. Many international patients combine their treatment with a vacation, making Playa del Carmen one of the top destinations for dental tourism in Mexico. From dental implants to veneers and full smile makeovers, you can achieve high-quality results while enjoying your stay.",
    linkText: "Learn more about dental tourism in Mexico and how it works.",
    url: "/en/dental-tourism-mexico"
  },
  es: {
    title: "Turismo Dental en México: ¿Por qué elegir Playa del Carmen?",
    text1: "El turismo dental en México se ha convertido en una opción confiable para miles de estadounidenses cada año. Playa del Carmen ofrece clínicas dentales modernas, profesionales experimentados y costos significativamente más bajos.",
    text2: "Los pacientes eligen Playa del Carmen no solo por la atención dental asequible, sino también por la seguridad, la accesibilidad y un entorno de recuperación confortable.",
    linkText: "Conoce más sobre el turismo dental en México y cómo funciona.",
    url: "/es/turismo-dental-mexico"
  }
};

const t = translations[lang];
---

<section class="tourism">
  <div class="container tourism__grid">
    <div class="tourism__content">
      <h2 class="tourism__title">{t.title}</h2>
      
      <div class="tourism__description">
        <p>{t.text1}</p>
        <p>{t.text2}</p>
      </div>

      <a href={t.url} class="tourism__link">
        <span class="emoji">👉</span> 
        <span class="link-text">{t.linkText}</span>
      </a>
    </div>

    <div class="tourism__video-wrapper">
      <div class="video-clean">
        <div class="video-clean__badge">
          <Icon name="map-pin" size={14} />
          <span>Playa del Carmen</span>
        </div>

        <iframe 
          src="https://www.instagram.com/p/DPCjErMDkTc/embed" 
          class="instagram-iframe-clean"
          scrolling="no" 
          allowtransparency="true" 
          frameborder="0">
        </iframe>
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --white: #ffffff;
    --text-gray: #444444;
  }

  .tourism {
    background-color: var(--white);
    padding: 8rem 0;
    overflow: hidden;
  }

  .container {
    margin: 0 auto;
    width: 90%;
  }

  .tourism__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .tourism__grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 6rem;
    }
  }

  .tourism__title {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--black);
    line-height: 1.1;
    margin-bottom: 2.5rem;
    text-transform: uppercase;
  }

  .tourism__description p {
    font-size: 1.1rem;
    color: var(--text-gray);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .tourism__link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--black);
    text-decoration: none;
    margin-top: 1.5rem;
    transition: all 0.3s ease;
  }

  .link-text {
    border-bottom: 2px solid var(--gold);
    padding-bottom: 2px;
  }

  .tourism__link:hover {
    color: var(--gold);
    transform: translateX(10px);
  }

  /* --- ESTILO LIMPIO PARA EL REEL --- */
  .tourism__video-wrapper {
    display: flex;
    justify-content: center;
  }

  .video-clean {
    position: relative;
    width: 100%;
    max-width: 320px; /* Ajustado para simular formato Reel */
  }

  .instagram-iframe-clean {
    width: 100%;
    aspect-ratio: 9 / 16; /* Formato vertical puro */
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    border: none;
  }

  .video-clean__badge {
    position: absolute;
    top: 15px;
    left: 15px;
    z-index: 5;
    background: var(--gold);
    color: white;
    padding: 6px 12px;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    letter-spacing: 1px;
    pointer-events: none;
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .tourism { padding: 4rem 0; }
    .tourism__title { font-size: 1.8rem; }
    .video-clean { max-width: 280px; }
  }
</style>