---
import { Icon } from "astro-icon/components";
import { routes } from "../../i18n/ui"; // Importamos las rutas oficiales

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

/**
 * Función para obtener la URL correcta según el idioma y la clave.
 * Se utiliza 'as keyof' para evitar el error de indexación dinámica en TypeScript.
 */
const getUrl = (key: string) => {
  const langRoutes = routes[lang as keyof typeof routes];
  const slug = langRoutes[key as keyof typeof langRoutes] || key;
  return `/${lang}/${slug}`;
};

const imgPathServicces = "/home/services/";

const translations = {
