        img: imgPathServicces + "Braces.webp",
      },
      {
        key: "dental_tourism",
        title: "Turismo Dental",
        alt: "Dental tourism in mexico",
        desc: "Soporte completo para pacientes internacionales que buscan atención segura.",
        img: imgPathServicces + "Dental-treatment.webp",
      },
    ],
    btnText: "OBTÉN UNA COTIZACIÓN GRATIS",
    whatsappMsg: "¡Hola! Me gustaría una cotización sin compromiso para mi tratamiento dental."

