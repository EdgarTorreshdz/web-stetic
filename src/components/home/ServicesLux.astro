        title: "Implantes Dentales",
        alt: "Dental implants in playa del carmen treatment",
        desc: "Soluciones permanentes para reemplazar dientes perdidos con resultados naturales.",
        img: imgPathServicces + "Dental-implant.webp",
      },
      {
        key: "veneers",
        title: "Carillas",
        alt: "veneers in playa del carmen smile",
        desc: "Carillas de porcelana personalizadas diseñadas para mejorar su sonrisa.",
        img: imgPathServicces + "VeneersVeeners.webp",
      },
      {
        key: "dental_crowns",
        title: "Coronas",
        alt: "Dental crowns in playa del carmen restoration",
        desc: "Coronas dentales duraderas que restauran la fuerza, función y apariencia natural.",
        img: imgPathServicces + "Crown.webp",
      },
      {
        key: "invisalign",
        title: "Invisalign",
        alt: "Clear aligners in playa del carmen treatment",
