---
import { Icon } from "astro-icon/components";

interface Props {
  lang?: 'en' | 'es';
}

const { lang = "en" } = Astro.props;

const translations = {
  en: {
    subtitle: "STETIC DENTAL QUALITY",
    title: "WHY INTERNATIONAL PATIENTS CHOOSE OUR DENTAL CLINIC IN PLAYA DEL CARMEN",
    introText: "We understand that choosing a dentist in another country can feel overwhelming. That’s why our dental clinic in Playa del Carmen is designed specifically for international patients looking for safe, high-quality, and reliable care.",
    benefits: [
      { 
        title: "Certified and experienced dental specialists",
        text: "Our team is trained in advanced procedures and follows international standards to ensure safe and predictable results.", 
        img: "/home/Iconos/certified-and-experienced-dental-specialist.png" 
      },
      { 
        title: "English-speaking team for clear communication",
        text: "We guide you through every step of your treatment in English, so you always feel informed and confident.", 
        img: "/home/Iconos/English-speaking-team-for-clear-communication.png" 
      },
      { 
        title: "Modern dental technology and materials",
        text: "We use advanced equipment and high-quality materials to deliver precise, long-lasting results.", 
        img: "/home/Iconos/Advanced-dental-technology-and-materials.png" 
      },
      { 
        title: "Transparent treatment plans and pricing",
        text: "You receive clear diagnostics and upfront pricing with no hidden costs.", 
        img: "/home/Iconos/Transparent-treatment-plans-and-pricing.png" 
      },
      { 
        title: "Personalized care for international patients",
        text: "From your first consultation to your follow-up, we provide a smooth and well-organized experience tailored to your needs.", 
        img: "/home/Iconos/Personalized-care-for-international-patients.png" 
      }
    ],
    footerText: "Thousands of patients trust us every year for their dental care in Playa del Carmen."
  },
  es: {
    subtitle: "CALIDAD STETIC DENTAL",
    title: "¿POR QUÉ LOS PACIENTES INTERNACIONALES ELIGEN NUESTRA CLÍNICA EN PLAYA DEL CARMEN?",
    introText: "Entendemos que elegir un dentista en otro país puede ser abrumador. Nuestra clínica en Playa del Carmen está diseñada específicamente para pacientes que buscan atención segura y confiable.",
    benefits: [
      { 
        title: "Especialistas certificados y experimentados",
        text: "Nuestro equipo está capacitado en procedimientos avanzados y sigue estándares internacionales para resultados seguros.", 
        img: "/home/Iconos/certified-and-experienced-dental-specialist.png" 
      },
      { 
        title: "Equipo bilingüe para una comunicación clara",
        text: "Te guiamos en cada paso de tu tratamiento en inglés o español, para que siempre te sientas informado.", 
        img: "/home/Iconos/English-speaking-team-for-clear-communication.png" 
      },
      { 
        title: "Tecnología y materiales avanzados",
        text: "Utilizamos equipos modernos y materiales de alta calidad para resultados precisos y duraderos.", 
        img: "/home/Iconos/Advanced-dental-technology-and-materials.png" 
      },
      { 
        title: "Planes y precios transparentes",
        text: "Recibes diagnósticos claros y precios honestos sin costos ocultos.", 
        img: "/home/Iconos/Transparent-treatment-plans-and-pricing.png" 
      },
      { 
        title: "Atención personalizada",
        text: "Desde tu primera consulta hasta el seguimiento, brindamos una experiencia organizada y adaptada a tus necesidades.", 
        img: "/home/Iconos/Personalized-care-for-international-patients.png" 
      }
    ],
    footerText: "Miles de pacientes confían en nosotros cada año para su cuidado dental en Playa del Carmen."
  }
};

const t = translations[lang];
---

<section class="why-choose">
  <div class="container-fluid">
    <div class="why-choose__header">
      <span class="why-choose__subtitle">{t.subtitle}</span>
      <h2 class="why-choose__title">{t.title}</h2>
      <p class="why-choose__intro">{t.introText}</p>
    </div>

    <div class="why-choose__grid">
      {t.benefits.map((benefit) => (
        <div class="benefit-item">
          <div class="benefit-item__icon-wrapper">
            <img src={benefit.img} alt={benefit.title} class="benefit-image" />
          </div>
          <h3 class="benefit-item__title">{benefit.title}</h3>
          <p class="benefit-item__description">{benefit.text}</p>
          <div class="benefit-item__line"></div>
        </div>
      ))}
    </div>

    <div class="why-choose__footer">
      <div class="why-choose__footer-content">
        <Icon name="insignia" size={40} class="footer-icon" />
        <p class="footer-text">{t.footerText}</p>
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --dark-accent: #0a0a0a;
    --white: #ffffff;
    --gray-border: #1a1a1a;
  }

  .why-choose {
    background-color: var(--black);
    color: var(--white);
    padding: 8rem 0;
  }

  .why-choose__header {
    text-align: center;
    margin-bottom: 5rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1rem;
  }

  .why-choose__subtitle {
    color: var(--gold);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1.2rem;
  }

  .why-choose__title {
    font-size: 2.1rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1.2;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .why-choose__intro {
    font-size: 1.1rem;
    color: #999;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  .why-choose__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 5rem;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .why-choose__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .why-choose__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1440px) {
    .why-choose__grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }
  }

  .benefit-item {
    padding: 2.5rem 1.5rem;
    background-color: var(--dark-accent);
    border: 1px solid var(--gray-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    min-height: 320px;
  }

  .benefit-item:hover {
    border-color: var(--gold);
    transform: translateY(-10px);
    background-color: #0f0f0f;
    box-shadow: 0 15px 30px rgba(0,0,0,0.5);
  }

  .benefit-item__icon-wrapper {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .benefit-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: all 0.3s ease;
  }

  .benefit-item:hover .benefit-image {
    filter: sepia(1) saturate(5) hue-rotate(10deg);
  }

  .benefit-item__title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1.3;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
    letter-spacing: 0.5px;
  }

  .benefit-item__description {
    font-size: 0.85rem;
    color: #ccc;
    line-height: 1.5;
  }

  .benefit-item__line {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 4px;
    background-color: var(--gold);
    transition: width 0.4s ease;
  }

  .benefit-item:hover .benefit-item__line {
    width: 60%;
  }

  .why-choose__footer {
    border-top: 1px solid var(--gray-border);
    padding-top: 4rem;
    max-width: 950px;
    margin: 0 auto;
  }

  .why-choose__footer-content {
    display: flex;
    align-items: center;
    gap: 2rem;
    text-align: left;
    padding: 0 1rem;
  }

  .footer-icon {
    color: var(--gold);
    flex-shrink: 0;
  }

  .footer-text {
    font-size: 1.2rem;
    color: var(--white);
    line-height: 1.6;
    font-weight: 600;
    font-style: italic;
  }

  .container-fluid {
    margin: 0 auto;
    width: 95%;
    max-width: 1600px;
  }

  @media (max-width: 768px) {
    .why-choose__title { font-size: 1.7rem; }
    .why-choose__footer-content {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }
  }
</style>