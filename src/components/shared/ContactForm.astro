---
interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.params as { lang: 'en' | 'es' } || Astro.props;

const content = {
  en: {
    title: "Book Your Dental Appointment in Playa del Carmen",
  },
  es: {
    title: "Reserva tu Cita Dental en Playa del Carmen",
  }
};

const t = content[lang] || content.en;
---

<section id="contact" class="contact-section">
  <div class="container">
    
    <h2 class="contact-title">
      {t.title}
    </h2>

    <div class="form-wrapper">
      {lang === 'es' ? (
        <!-- Formulario en Español -->
        <>
          <script is:inline>!function(a,m,o,c,r,m){a[o+c]=a[o+c]||{setMeta:function(p){this.params=(this.params||[]).concat([p])}},a[o+r]=a[o+r]||function(f){a[o+r].f=(a[o+r].f||[]).concat([f])},a[o+r]({id:"1709255",hash:"01fdfc2c60cbd7d1c84b4c9b78d98764",locale:"en"}),a[o+m]=a[o+m]||function(f,k){a[o+m].f=(a[o+m].f||[]).concat([[f,k]])}}(window,0,"amo_forms_","params","load","loaded");</script>
          <script is:inline id="amoforms_script_1709255" async="async" charset="utf-8" src="https://forms.kommo.com/forms/assets/js/amoforms.js?1779135956"></script>
        </>
      ) : (
        <!-- Formulario en Inglés -->
        
        <>
          <script is:inline>!function(a,m,o,c,r,m){a[o+c]=a[o+c]||{setMeta:function(p){this.params=(this.params||[]).concat([p])}},a[o+r]=a[o+r]||function(f){a[o+r].f=(a[o+r].f||[]).concat([f])},a[o+r]({id:"1709251",hash:"4f406440ca446a52d808204e83cd315a",locale:"es"}),a[o+m]=a[o+m]||function(f,k){a[o+m].f=(a[o+m].f||[]).concat([[f,k]])}}(window,0,"amo_forms_","params","load","loaded");</script>
          <script is:inline id="amoforms_script_1709251" async="async" charset="utf-8" src="https://forms.kommo.com/forms/assets/js/amoforms.js?1779135166"></script>
        </>
      )}
    </div>

  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --white: #ffffff;
  }

  .contact-section {
    padding: 6rem 0;
    background-color: var(--black);
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .container {
    width: 90%;
    max-width: 900px; 
    margin: 0 auto;
  }

  .contact-title {
    text-align: center;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 3rem;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .form-wrapper {
    width: 100%;
    /* Mantenemos un alto mínimo para evitar brincos bruscos en el diseño mientras carga el script de Kommo */
    min-height: 700px;
    height: auto;
    background-color: transparent; 
    padding: 0; 
    border: none; 
    box-shadow: none; 
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 4rem 0;
    }
    .contact-title {
      font-size: 1.7rem;
      margin-bottom: 2rem;
    }
    .form-wrapper {
      min-height: 850px;
    }
  }
</style>