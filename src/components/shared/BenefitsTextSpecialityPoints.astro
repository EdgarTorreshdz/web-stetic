---
interface Props {
  title: string;
  text1: string;
  text2?: string;
  text3?: string;
  listItems?: string[];
  conclusion?: string;
}

const { title, text1, text2, text3, listItems = [], conclusion } = Astro.props;
---

<section class="benefits-text">
  <div class="container">
    <div class="benefits-text__card">
      <h2 class="benefits-text__title">{title}</h2>
      <div class="benefits-text__accent-line"></div>
      
      <div class="benefits-text__content">
        <p class="benefits-text__main">
          {text1}
        </p>
        
        <div class="benefits-text__divider"></div>
        
        <p class="benefits-text__secondary">
          {text2}
        </p>

        {text3 && (
          <p class="benefits-text__secondary benefits-text__intro">
            {text3}
          </p>
        )}

        {listItems && listItems.length > 0 && (
          <ul class="benefits-text__list">
            {listItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}

        {conclusion && (
          <p class="benefits-text__conclusion">
            {conclusion}
          </p>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --white: #ffffff;
  }

  .benefits-text {
    padding: 100px 0;
    background-color: #f9f9f9; 
  }

  .container {
    margin: 0 auto;
    width: 85%;
    max-width: 1000px;
  }

  .benefits-text__card {
    background-color: var(--white);
    padding: 60px 50px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(165, 142, 85, 0.1);
  }

  .benefits-text__title {
    font-size: 2.2rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 20px;
  }

  .benefits-text__accent-line {
    width: 60px;
    height: 3px;
    background-color: var(--gold);
    margin: 0 auto 40px;
  }

  .benefits-text__main {
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--black);
    margin-bottom: 30px;
  }

  .benefits-text__divider {
    width: 40px;
    height: 1px;
    background-color: #eee;
    margin: 0 auto 30px;
  }

  .benefits-text__secondary {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #555;
    margin: 0 0 15px 0;
  }

  .benefits-text__intro {
    font-weight: 600;
    margin-top: 20px;
    margin-bottom: 20px;
  }

  /* Estilos para mantener la lista legible dentro de una tarjeta centrada */
  .benefits-text__list {
    list-style: none;
    padding: 0;
    margin: 0 0 35px 0;
    display: inline-block;
    text-align: left; /* Mantiene la viñeta y el texto alineados a la izquierda */
  }

  .benefits-text__list li {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #555;
    position: relative;
    padding-left: 20px;
    margin-bottom: 10px;
  }

  .benefits-text__list li::before {
    content: "•";
    color: var(--gold);
    font-size: 1.5rem;
    position: absolute;
    left: 0;
    top: -4px;
  }

  /* Estilo destacado para la conclusión dentro de la tarjeta */
  .benefits-text__conclusion {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--black);
    background-color: rgba(165, 142, 85, 0.05);
    padding: 20px;
    border-radius: 12px;
    margin: 0 auto;
    max-width: 800px;
  }

  @media (max-width: 768px) {
    .benefits-text { padding: 60px 0; }
    .benefits-text__card { padding: 40px 25px; }
    .benefits-text__title { font-size: 1.8rem; }
    .benefits-text__main { font-size: 1.15rem; }
    .benefits-text__list li { font-size: 1rem; }
  }
</style>