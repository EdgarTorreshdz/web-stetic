---
interface Props {
  lang: 'en' | 'es';
  title: string;
  description: string;
  buttonText?: string; // Mantengo la prop aunque no se use en este form
  note: string;
}

const { lang = "en", title, description, note } = Astro.props;
---

<section id="contact" class="cta-section">
  <div class="container">
    <div class="cta__card">
      <h2 class="cta__title">{title}</h2>
      <div class="cta__accent-line"></div>
      
      <p class="cta__description">
        {description}
      </p>

      <!-- Contenedor donde Kommo inyectará el formulario -->
      <div class="cta__form-container">
        {lang === 'es' ? (
          <>
            <script is:inline>!function(a,m,o,c,r,m){a[o+c]=a[o+c]||{setMeta:function(p){this.params=(this.params||[]).concat([p])}},a[o+r]=a[o+r]||function(f){a[o+r].f=(a[o+r].f||[]).concat([f])},a[o+r]({id:"1709255",hash:"01fdfc2c60cbd7d1c84b4c9b78d98764",locale:"es"}),a[o+m]=a[o+m]||function(f,k){a[o+m].f=(a[o+m].f||[]).concat([[f,k]])}}(window,0,"amo_forms_","params","load","loaded");</script>
            <script is:inline id="amoforms_script_1709255" async="async" charset="utf-8" src="https://forms.kommo.com/forms/assets/js/amoforms.js?1779135956"></script>
          </>
        ) : (
          <>
            <script is:inline>!function(a,m,o,c,r,m){a[o+c]=a[o+c]||{setMeta:function(p){this.params=(this.params||[]).concat([p])}},a[o+r]=a[o+r]||function(f){a[o+r].f=(a[o+r].f||[]).concat([f])},a[o+r]({id:"1709251",hash:"4f406440ca446a52d808204e83cd315a",locale:"en"}),a[o+m]=a[o+m]||function(f,k){a[o+m].f=(a[o+m].f||[]).concat([[f,k]])}}(window,0,"amo_forms_","params","load","loaded");</script>
            <script is:inline id="amoforms_script_1709251" async="async" charset="utf-8" src="https://forms.kommo.com/forms/assets/js/amoforms.js?1779135166"></script>
          </>
        )}
      </div>
      
      <p class="cta__note">
        {note}
      </p>
    </div>
  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --white: #ffffff;
  }

  .cta-section {
    padding: 100px 0;
    background-color: var(--black);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(165, 142, 85, 0.08) 0%, rgba(0,0,0,0) 70%);
    transform: translate(-50%, -50%);
    z-index: 0;
  }

  .container {
    margin: 0 auto;
    width: 90%;
    position: relative;
    z-index: 1;
  }

  .cta__card {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 60px 20px;
    border: 1px solid rgba(165, 142, 85, 0.2);
    background-color: rgba(255, 255, 255, 0.01);
  }

  .cta__title {
    font-size: 2.2rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .cta__title { font-size: 3.2rem; }
  }

  .cta__accent-line {
    width: 80px;
    height: 3px;
    background-color: var(--gold);
    margin: 0 auto 30px auto;
  }

  .cta__description {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e0e0e0;
    margin-bottom: 40px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Contenedor del formulario Kommo */
  .cta__form-container {
    width: 100%;
    margin: 0 auto;
    min-height: 600px;
  }

  .cta__note {
    font-size: 0.9rem;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-top: 30px;
  }

  @media (max-width: 768px) {
    .cta__card {
      padding: 40px 15px;
    }
  }
</style>