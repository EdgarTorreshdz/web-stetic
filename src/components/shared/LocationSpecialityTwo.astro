---
interface Props {
  title: string;
  text1: string;
  text2: string;
  addressTitle: string;
  addressText: string;
  addressLink: string;
  hoursTitle: string;
  hours: string[];
  ctaText: string;
  whatsappText: string;
  whatsappUrl: string;
  mapEmbedUrl: string;
  mapCaption: string;
}

const { 
  title, 
  text1, 
  text2,
  addressTitle,
  addressText,
  addressLink,
  hoursTitle,
  hours,
  ctaText,
  whatsappText,
  whatsappUrl = "#",
  mapEmbedUrl,
  mapCaption
} = Astro.props;
---

<section class="location-section">
  <div class="container">
    <div class="location__grid">
      
      {/* --- Columna Izquierda: Información de Contacto --- */}
      <div class="location__content">
        <h2 class="location__title">{title}</h2>
        <div class="location__accent-line"></div>

        <p class="location__text">{text1}</p>
        <p class="location__text">{text2}</p>

        <div class="location__details">
          
          <div class="detail-item">
            <span class="emoji">📍</span>
            <div class="detail-text">
              <strong>{addressTitle}</strong><br />
              <a
                href={addressLink}
                target="_blank"
                rel="noopener noreferrer"
                class="location__link"
              >
                {addressText}
              </a>
            </div>
          </div>

          <div class="detail-item">
            <span class="emoji">🕒</span>
            <div class="detail-text">
              <strong>{hoursTitle}</strong><br />
              {hours.map((hour) => (
                <Fragment>
                  {hour}<br />
                </Fragment>
              ))}
            </div>
          </div>

        </div>

        {/* CTA movido a la izquierda como pediste */}
        
      </div>

      {/* --- Columna Derecha: Mapa --- */}
      <div class="location__map-side">
        <div class="location__map-wrapper">
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="450"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="location__map">
          </iframe>
        </div>
        <p class="location__map-caption">
          {mapCaption}
        </p>
      </div>

    </div>
    <div class="location__cta">
          <p set:html={ctaText}></p>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp"
          >
            {whatsappText}
          </a>
        </div>
  </div>
</section>

<style>
  :root {
    --gold: #a58e55;
    --black: #000000;
    --white: #ffffff;
    --text-gray: #444444;
  }

  .location-section {
    padding: 80px 0;
    background-color: var(--white);
    color: var(--black);
  }

  .container {
    margin: 0 auto;
    width: 85%;
  }

  /* --- Grid Layout --- */
  .location__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 50px;
    align-items: start;
  }

  @media (min-width: 992px) {
    .location__grid {
      grid-template-columns: 1fr 1fr;
      gap: 60px;
    }
  }

  /* --- Columna Izquierda --- */
  .location__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .location__title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.2;
    margin-bottom: 20px;
    color: var(--black);
  }

  @media (min-width: 768px) {
    .location__title {
      font-size: 2.5rem;
    }
  }

  .location__accent-line {
    width: 80px;
    height: 3px;
    background-color: var(--gold);
    margin-bottom: 30px;
  }

  .location__text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-gray);
    margin: 0 0 20px 0;
  }

  /* --- Detalles (Ubicación y Horarios) --- */
  .location__details {
    display: flex;
    flex-direction: column;
    gap: 25px;
    margin-top: 15px;
    margin-bottom: 35px;
    width: 100%;
  }

  .detail-item {
    display: flex;
    align-items: flex-start;
    gap: 15px;
  }

  .emoji {
    font-size: 1.5rem;
    line-height: 1.2;
  }

  .detail-text {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-gray);
  }

  .detail-text strong {
    color: var(--black);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .location__link {
    color: var(--gold);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
    display: inline-block;
    margin-top: 5px;
  }

  .location__link:hover {
    color: var(--black);
    text-decoration: underline;
  }

  /* --- CTA y Botón WhatsApp --- */
  .location__cta {
    background-color: rgba(165, 142, 85, 0.05);
    border-left: 4px solid var(--gold);
    border-radius: 4px;
    width: 100%;
    text-align: left; /* Alineado a la izquierda para encajar con la columna */
  }

  .location__cta p {
    font-size: 1rem;
    color: var(--text-gray);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    background-color: #25d366; 
    color: var(--white);
    padding: 12px 24px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    border-radius: 50px;
    transition: transform 0.3s ease, background-color 0.3s ease;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }

  .btn-whatsapp:hover {
    background-color: #1ebe57;
    transform: translateY(-2px);
  }

  /* --- Columna Derecha: Mapa --- */
  .location__map-side {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .location__map-wrapper {
    position: relative;
    padding: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .location__map-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 2px solid var(--gold);
    z-index: 0;
    pointer-events: none;
    border-radius: 8px;
  }

  .location__map {
    width: 100%;
    display: block;
    position: relative;
    z-index: 1;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
    border-radius: 4px;
  }

  .location__map-caption {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-gray);
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 768px) {
    .location-section {
      padding: 60px 0;
    }
    .location__map {
      height: 350px;
    }
    .location__cta {
      text-align: center;
    }
  }
</style>