---
interface Specialist {
  name: string;
  specialty: string;
  image: string;
  bio: string;
}

interface Props {
  title?: string;
  description?: string;
  specialists: Specialist[];
}

const {
  title = "Trusted Dental Specialists for International Patients",
  description = "Choosing the right dental team is one of the most important decisions when planning treatment abroad. Our specialists provide personalized care, clear communication in English, and modern dental solutions designed to help patients travel confidently to Playa del Carmen for their treatment.",
  specialists
} = Astro.props;
---

<section class="team-section">
  <div class="container">
    <div class="team__header">
      <h2 class="team__title">{title}</h2>
      <div class="team__accent-line"></div>
      <p class="team__description">{description}</p>
    </div>

    <div class="team__grid">
      {specialists.map((specialist) => (
        <div class="team__card">
          <div class="team__image-wrapper">
            <img 
              src={specialist.image} 
              alt={`Portrait of ${specialist.name}`} 
              class="team__image" 
              loading="lazy" 
            />
          </div>
          <div class="team__info">
            <h3 class="team__name">{specialist.name}</h3>
            <p class="team__specialty">{specialist.specialty}</p>
            <p class="team__bio">{specialist.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  :root {
    --gold: #A58E55;
    --black: #000000;
    --white: #ffffff;
    --light-gray: #f9f9f9;
    --text-gray: #444444;
  }

  .team-section {
    padding: 80px 0;
    background-color: var(--white);
  }

  .container {
    margin: 0 auto;
    width: 90%;
    max-width: 1200px;
  }

  .team__header {
    text-align: center;
    max-width: 850px;
    margin: 0 auto 50px auto;
  }

  .team__title {
    font-size: 2rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .team__title { font-size: 2.5rem; }
  }

  .team__accent-line {
    width: 60px;
    height: 3px;
    background-color: var(--gold);
    margin: 0 auto 25px auto;
  }

  .team__description {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-gray);
    white-space: pre-line;
  }

  /* Grid que se adapta automáticamente al número de dentistas */
  .team__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-top: 40px;
  }

  @media (min-width: 768px) {
    .team__grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  .team__card {
    background-color: var(--light-gray);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .team__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
  }

  .team__image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 5; /* Proporción ideal para retratos */
    overflow: hidden;
    background-color: #eaeaea; 
  }

  .team__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center; /* Asegura que la cara no se corte */
    transition: transform 0.5s ease;
  }

  .team__card:hover .team__image {
    transform: scale(1.05); /* Efecto de zoom elegante al hover */
  }

  .team__info {
    padding: 30px 25px;
    text-align: center;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .team__name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 5px;
  }

  .team__specialty {
    font-size: 0.95rem;
    color: var(--gold);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 15px;
    letter-spacing: 1px;
  }

  .team__bio {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-gray);
    margin: 0;
  }
</style>