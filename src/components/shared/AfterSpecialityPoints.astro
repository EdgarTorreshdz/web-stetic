---
import ButtonCTA from "./ButtonCTA.astro";

interface Props {
  title: string;
  text1: string;
  text2?: string;
  footerText?: string;
  imageSrc: string;
  imageAlt: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  title,
  text1,
  text2,
  footerText,
  imageSrc,
  imageAlt,
  buttonText,
  buttonLink,
} = Astro.props;
---

<section class="about-section">
  <div class="container">
    <div class="about__grid">
      <div class="about__image-container">
        <div class="about__img-frame">
          <img src={imageSrc} alt={imageAlt} class="about__img" />
        </div>
      </div>

      <div class="about__content">
        <h2 class="about__title">{title}</h2>
        <div class="about__accent-line"></div>
        <p class="about__text about__text--highlight">
          {text1}
        </p>
        <p class="about__text">
          {text2}
        </p>
      </div>
    </div>

    {
      footerText && (
        <div class="about__footer">
          <p class="about__footer-text">{footerText}</p>
        </div>
      )
    }

    {
      buttonText && buttonLink && (
        <div style="margin-top: 40px;">
          <ButtonCTA
            text={buttonText}
            href={buttonLink}
            openInNewTab={true}
            align="center"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  :root {
    --gold: #a58e55;
    --black: #000000;
    --white: #ffffff;
  }

  .about-section {
    padding: 100px 0;
    background-color: var(--black);
    color: var(--white);
  }

  .container {
    margin: 0 auto;
    width: 85%;
  }

  .about__grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  @media (min-width: 992px) {
    .about__grid {
      flex-direction: row;
      justify-content: space-between;
      gap: 60px;
    }
  }

  .about__content {
    flex: 1.2;
    text-align: left;
  }

  .about__title {
    font-size: 1.8rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.2;
    margin-bottom: 20px;
    color: var(--white);
  }

  @media (min-width: 768px) {
    .about__title {
      font-size: 2.5rem;
    }
  }

  .about__accent-line {
    width: 80px;
    height: 3px;
    background-color: var(--gold);
    margin-bottom: 30px;
  }

  .about__text {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 20px;
    color: #e0e0e0;
  }

  .about__text--highlight {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
    border-left: 4px solid var(--gold);
    padding-left: 20px;
  }

  @media (min-width: 768px) {
    .about__text {
      font-size: 1.1rem;
    }
    .about__text--highlight {
      font-size: 1.3rem;
    }
  }

  .about__image-container {
    flex: 1;
    width: 100%;
  }

  .about__img-frame {
    position: relative;
    border: 1px solid rgba(165, 142, 85, 0.4);
    padding: 10px;
  }

  .about__img-frame::before {
    content: "";
    position: absolute;
    top: -5px;
    left: -5px;
    width: 40px;
    height: 40px;
    border-top: 3px solid var(--gold);
    border-left: 3px solid var(--gold);
  }

  .about__img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }

  @media (min-width: 992px) {
    .about__img {
      max-height: 450px;
    }
  }

  .about__footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--gold);
  }

  .about__footer-text {
    font-size: 1rem;
    line-height: 1.6;
    color: #ffffff;
    white-space: pre-line;
  }
</style>
