---
import ButtonCTA from "./ButtonCTA.astro";

const title = "Compare Dental Implant Options";

const tableData = [
  {
    treatment: "Single Tooth Implant",
    bestFor: "Replacing one missing tooth",
    time: "1–3 months",
    durability: "15–25+ years",
    cost: "$900 – $1,500",
  },
  {
    treatment: "Multiple Dental Implants",
    bestFor: "Replacing several teeth",
    time: "2–4 months",
    durability: "15–25+ years",
    cost: "$2,500 – $6,000",
  },
  {
    treatment: "Full Mouth Dental Implants",
    bestFor: "Full smile restoration",
    time: "3–6 months",
    durability: "20+ years",
    cost: "$8,000 – $15,000",
  },
  {
    treatment: "All-on-4 Dental Implants",
    bestFor: "Full arch with fewer implants",
    time: "1–3 days (initial) + healing",
    durability: "15–20+ years",
    cost: "$6,500 – $12,000",
  },
];
const buttonText = "Schedule you free video consultation";
const phoneNumber = "5219844922549";
const whatsappUrl = `https://wa.me/${phoneNumber}/?text=${"Hello! I'm interested in learning more about your services."}`;
---

<section class="compare-section">
  <div class="container">
    <h3 class="compare__title">{title}</h3>
    <div class="compare__accent-line"></div>

    <div class="table-wrapper">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Treatment</th>
            <th>Best For</th>
            <th>Treatment Time</th>
            <th>Durability</th>
            <th>Estimated Cost (USD)</th>
          </tr>
        </thead>
        <tbody>
          {
            tableData.map((row) => (
              <tr>
                <td class="fw-bold">{row.treatment}</td>
                <td>{row.bestFor}</td>
                <td>{row.time}</td>
                <td>{row.durability}</td>
                <td class="text-gold fw-bold">{row.cost}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="compare__disclaimer">
      <strong>Note:</strong> Prices may vary depending on your case. Contact us for
      a personalized treatment plan and exact quote.
    </p>
    <ButtonCTA
      text={buttonText}
      href={whatsappUrl}
      openInNewTab={true}
      align="center"
    />
  </div>
</section>

<style>
  :root {
    --gold: #a58e55;
    --black: #000000;
    --white: #ffffff;
    --text-gray: #444444;
    --light-gray: #f9f9f9;
    --border-color: #eaeaea;
  }

  .compare-section {
    padding: 80px 0;
    background-color: var(--white);
  }

  .container {
    margin: 0 auto;
    width: 90%;
  }

  .compare__title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--black);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 15px;
  }

  .compare__accent-line {
    width: 60px;
    height: 3px;
    background-color: var(--gold);
    margin: 0 auto 40px auto;
  }

  /* --- Contenedor Responsivo --- */
  .table-wrapper {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-radius: 12px;
    background-color: var(--white);
    margin-bottom: 2rem; /* Espacio para el disclaimer */
  }

  /* --- Estilos de la Tabla --- */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    min-width: 800px;
  }

  .compare-table th,
  .compare-table td {
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
  }

  .compare-table thead {
    background-color: var(--black);
    color: var(--white);
  }

  .compare-table th {
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  .compare-table tbody tr {
    transition: background-color 0.3s ease;
  }

  .compare-table tbody tr:hover {
    background-color: var(--light-gray);
  }

  .compare-table td {
    color: var(--text-gray);
    font-size: 1.05rem;
    line-height: 1.5;
  }

  /* --- Estilo del Disclaimer --- */
  .compare__disclaimer {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-gray);
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* --- Utilidades de Texto --- */
  .fw-bold {
    font-weight: 700;
    color: var(--black);
  }

  .text-gold {
    color: var(--gold) !important;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .compare-section {
      padding: 60px 0;
    }
    .compare__title {
      font-size: 1.6rem;
    }
    .compare-table th,
    .compare-table td {
      padding: 15px;
      font-size: 0.95rem;
    }
    .compare__disclaimer {
      font-size: 0.85rem;
      padding: 0 10px;
    }
  }
</style>
